# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Environment files (all variants, all folders) ──────────────
# Ignores .env, .env.local, .env.production, backend/.env, ml/.env, etc.
# Keeps .env.example tracked everywhere so teammates have a template.
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# ── Dependencies (Node / pnpm / yarn) ───────────────────────────
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js (frontend) ──────────────────────────────────────────
.next/
**/.next/
/out/
.turbo/

# ── Production build (frontend / backend) ───────────────────────
build/
dist/
**/build/
**/dist/

# ── Testing ──────────────────────────────────────────────────────
coverage/
**/coverage/

# ── TypeScript ───────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Debug logs ─────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Package manager caches ──────────────────────────────────────
.npm
.pnpm-store
.cache
.eslintcache
.stylelintcache

# ── Vercel ────────────────────────────────────────────────────────
.vercel

# ── Python / Backend virtual environments ────────────────────────
.venv/
venv/
**/.venv/
**/venv/

# ── Python cache ──────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.egg-info/

# ── ML-specific ────────────────────────────────────────────────────
ml/.ipynb_checkpoints/
ml/*.pkl
ml/*.h5
ml/*.pt
ml/*.pth
ml/models/*.bin
ml/data/raw/
ml/mlruns/
ml/wandb/

# ── Editor & IDE ───────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# ── OS files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem